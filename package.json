{
	"name": "ifunny-discord-bot",
	"version": "2.0.4",
	"description": "Discord bot with iFunny integration",
	"main": "dist/index.ts",
	"types": "types",
	"scripts": {
		"test": "jest",
		"start": "ts-node .\\index.ts",
		"changelog": "auto-changelog -p",
		"changelog-debug": "auto-changelog -p --template json --output changelog-data.json",
		"type": "tsc --declaration --emitDeclarationOnly --outFile index.d.ts",
		"build": "npx tsc && npm run type"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MakeShiftArtist/ifunny-discord-bot.git"
	},
	"keywords": [
		"Discord",
		"iFunny",
		"Bot",
		"Framework"
	],
	"author": "",
	"license": "GPL-3.0-or-later",
	"bugs": {
		"url": "https://github.com/MakeShiftArtist/ifunny-discord-bot/issues"
	},
	"homepage": "https://github.com/MakeShiftArtist/ifunny-discord-bot#readme",
	"devDependencies": {
		"@types/jest": "^27.5.1",
		"@types/node": "^17.0.33",
		"auto-changelog": "^2.4.0",
		"jest": "^28.1.0",
		"ts-jest": "^28.0.3",
		"ts-node": "^10.8.0",
		"typescript": "^4.6.4"
	},
	"dependencies": {
		"@discordjs/rest": "^0.4.1",
		"discord.js": "^13.7.0",
		"dotenv": "^16.0.1",
		"tiny-typed-emitter": "^2.1.0",
		"tslog": "^3.3.3"
	},
	"auto-changelog": {
		"template": "changelog-template.hbs",
		"hideEmptyReleases": true,
		"commitLimit": false,
		"unreleased": true,
		"replaceText": {
			"[Ff]eat:": "",
			"[Ff]ix:": "",
			"[Bb]reak:": "",
			"[Dd]oc:": ""
		}
	}
}
